# Display name the bot shows inside Meet when joining as a guest.
# Ignored if the Chrome profile is already signed into a Google account.
BOT_DISPLAY_NAME=Bogdanov

# macOS avfoundation audio input name. Must match `ffmpeg -f avfoundation -list_devices true -i ""` output.
AUDIO_INPUT=:BlackHole 2ch

# Groq API key (for Whisper STT). Get from console.groq.com.
GROQ_API_KEY=gsk_...
